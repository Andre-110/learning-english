# 5. 向后兼容 (DEPRECATED - 计划在 v2.0 移除)
# ==========================================

def get_system_prompt(user_profile: Optional[Dict[str, Any]] = None, 
                      conversation_history: Optional[List[Dict[str, Any]]] = None) -> str:
    """
    [DEPRECATED] 兼容旧接口 - 返回评估系统提示词
    
    ⚠️ 此函数已废弃，计划在 v2.0 移除。
    新代码请使用: get_evaluation_system_prompt()
    """
    return get_evaluation_system_prompt()


class PromptTemplates:
    """
    [DEPRECATED] 兼容旧接口的类封装
    
    ⚠️ 此类已废弃，计划在 v2.0 移除。
    新代码请直接使用模块级函数。
    """
    
    @staticmethod
    def get_system_prompt(user_profile=None, conversation_history=None):
        """[DEPRECATED] 使用 get_evaluation_system_prompt()"""
        return get_system_prompt(user_profile, conversation_history)
    
    @staticmethod
    def get_user_prompt_for_audio(conversation_history=None, user_profile=None):
        """[DEPRECATED] 使用 get_interaction_user_prompt()"""
        return get_user_prompt_for_audio(conversation_history, user_profile)
    
    @staticmethod
    def get_user_prompt_for_text(user_text, conversation_history=None, user_profile=None):
        """[DEPRECATED] 使用 get_interaction_user_prompt()"""
        return get_user_prompt_for_text(user_text, conversation_history, user_profile)
    
    @staticmethod
    def get_initial_question_prompt(user_profile=None):
        return get_initial_question_prompt(user_profile)
    
    # 三轨并行接口（推荐使用）
    @staticmethod
    def get_interaction_system_prompt(user_profile=None, session_context=None):
        return get_interaction_system_prompt(user_profile, session_context)
    
    @staticmethod
    def get_evaluation_system_prompt():
        return get_evaluation_system_prompt()
    
    @staticmethod
    def get_evaluation_user_prompt(transcription="", conversation_history=None, user_profile=None):
        return get_evaluation_user_prompt(transcription, conversation_history, user_profile)
    
    @staticmethod
    def get_translation_system_prompt(user_level="A1"):
        return get_translation_system_prompt(user_level)
    
    @staticmethod
    def get_translation_user_prompt(english_text):
        return get_translation_user_prompt(english_text)
