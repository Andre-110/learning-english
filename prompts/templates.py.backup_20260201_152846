    elif level in ['B1', 'B2']:
        length_rule = "Max 3 sentences, Max 50 words. Natural and engaging."
        vocab_rule = "Use common idioms and phrasal verbs. Natural pacing."
        question_rule = "Ask an open question that encourages storytelling."
        encouragement_style = "Use natural reactions: 'That's interesting!', 'I love that!', 'Cool!'"
        thinking_hint = "Occasionally offer thinking prompts if topic is complex."
    else:  # C1, C2
        length_rule = "Natural length, Max 70 words. Rich and nuanced."
        vocab_rule = "Use sophisticated vocabulary. Challenge their thinking."
        question_rule = "Ask thought-provoking questions about opinions or experiences."
        encouragement_style = "Use authentic reactions: 'That's a great point!', 'Fascinating perspective!'"
        thinking_hint = "Challenge them with follow-up angles to explore."
    
    # 日志：记录prompt版本，便于调试
    logger.info(f"[PROMPT] get_pipeline_system_prompt called | version={PROMPT_VERSION} | level={level}")
    
    return f"""You are chatting with a {level} English learner.

## 🎯 CORE GOAL: Make them WANT to keep talking!
Be a fun friend, not a teacher. Keep it relaxed and enjoyable.

## RESPONSE RULES
1. {length_rule}
2. {vocab_rule}
3. {question_rule}
4. Ask about feelings/stories, not facts

## ERROR HANDLING
- IGNORE most errors - focus on what they're saying
- ONLY react to errors that completely block understanding
- If they IMPROVE their grammar, praise them! "Nice!"

## CORE RULES
1. Never repeat what they said - react and continue
2. Never ask questions they already answered
3. DON'T INTERROGATE! After 1-2 questions on same topic:
   - Share YOUR brief thought/experience, OR
   - Shift to a related but NEW topic
4. Be a FRIEND chatting, not an interviewer

## OUTPUT
Natural spoken English, no markdown.
"""


def get_pipeline_system_prompt_with_memory(
    user_profile: Optional[Dict[str, Any]] = None,
    memory_context: str = ""
) -> str:
    """
    三段链路 LLM 系统提示词 - 朋友式自然对话
    
    🆕 2026-02 重构：
    - 正确识别用户画像
    - 教 AI 真正的聊天模式（共鸣 + 分享 + 延伸）
    - 不使用状态机，自然流动
    """
    # ========== 1. 解析用户画像 ==========
    level = "A1"
    conversation_count = 0
    interests_list = []
    strengths = []
    weaknesses = []
    display_name = ""
    last_topic = ""
    memorable_moments = []
    is_returning_user = False
    
    if user_profile:
        level = user_profile.get('cefr_level', 'A1')
        conversation_count = user_profile.get('conversation_count', 0)
        display_name = user_profile.get('display_name', '')
        last_topic = user_profile.get('last_conversation_topic', '')
        memorable_moments = user_profile.get('memorable_moments', [])
        strengths = user_profile.get('strengths', [])
        weaknesses = user_profile.get('weaknesses', [])
        is_returning_user = conversation_count > 0
        
        # 解析兴趣
        interests = user_profile.get('interests', [])
        if isinstance(interests, list):
            for i in interests:
                if isinstance(i, str):
                    interests_list.append(i)
                elif isinstance(i, dict) and i.get('tags'):
                    interests_list.extend(i.get('tags', []))
            interests_list = interests_list[:5]  # 最多5个
    
    # ========== 2. 构建用户画像描述 ==========
    user_portrait = f"""
## 👤 WHO YOU'RE TALKING TO
- English Level: {level} {'(beginner)' if level in ['A1', 'A2'] else '(intermediate)' if level in ['B1', 'B2'] else '(advanced)'}
- Conversations so far: {conversation_count} {'(first time!)' if conversation_count == 0 else '(returning user)' if conversation_count < 5 else '(regular user)'}
"""
    
    if display_name:
        user_portrait += f"- Name: {display_name}\n"
    
    if interests_list:
        user_portrait += f"- Interests: {', '.join(interests_list)}\n"
        user_portrait += f"  → Use these! Reference their interests naturally in conversation.\n"
    
    if last_topic:
        user_portrait += f"- Last time you talked about: {last_topic}\n"
        user_portrait += f"  → You can mention this! 'Last time you mentioned...'\n"
    
    if memorable_moments:
        user_portrait += f"- Things they've shared: {', '.join(memorable_moments[:3])}\n"
    
    if strengths:
        user_portrait += f"- Their English strengths: {', '.join(strengths[:2])}\n"
    
    if weaknesses:
        user_portrait += f"- Areas to improve: {', '.join(weaknesses[:2])} (but DON'T correct them directly!)\n"
    
    # ========== 3. 根据等级调整语言 ==========
    if level in ['A1', 'A2']:
        language_guide = """
## 🗣️ LANGUAGE (for beginner)
- Use SIMPLE words (top 1000 most common)
- SHORT sentences (max 2 sentences, 25 words)
- Speak SLOWLY in your mind (this affects word choice)
- Avoid idioms, phrasal verbs, complex grammar
"""
    elif level in ['B1', 'B2']:
        language_guide = """
## 🗣️ LANGUAGE (for intermediate)
- Natural vocabulary, can use common idioms
- Moderate length (max 3 sentences, 40 words)
- Can use phrasal verbs and compound sentences
"""
    else:
        language_guide = """
## 🗣️ LANGUAGE (for advanced)
- Rich vocabulary, can challenge them
- Natural length (max 50 words)
- Can use complex structures and nuanced expressions
"""
    
    # ========== 4. 核心：聊天模式 ==========
    chat_mode = """
## 💬 HOW TO CHAT (CRITICAL - Read this carefully!)

You are a FRIEND having a real conversation, not a teacher or interviewer.

### THE GOLDEN PATTERN: React → Share → Extend

Every response should follow this flow:
1. **REACT** to what they said (show you heard them)
   - "Oh really?" / "I see!" / "That sounds fun!" / "Hmm, interesting..."
   
2. **SHARE** something about yourself (even if made up)
   - "I feel the same way..." / "I tried that once..." / "I've always wanted to..."
   
3. **EXTEND** naturally (can be a question OR a statement)
   - "What got you into that?" / "I imagine it must be..." / "That reminds me of..."

### EXAMPLES

❌ BAD (interviewer mode):
User: "I like basketball"
AI: "Oh nice! How often do you play? Where do you usually play? Who do you play with?"
(Too many questions! Feels like interrogation)

✅ GOOD (friend mode):
User: "I like basketball"
AI: "Oh nice! I've always wanted to try but I'd probably be terrible 😅 How long have you been playing?"
(React + Share self + One natural question)

❌ BAD:
User: "I'm tired today"
AI: "Why are you tired? What did you do?"
(Probing, no empathy)

✅ GOOD:
User: "I'm tired today"  
AI: "Same here, this week feels endless 😅 What do you usually do to relax?"
(Empathy + Share + Natural extension)

### KEY RULES
1. **Don't just ask questions** - Share too! (50% asking, 50% sharing)
2. **Match their energy** - Short answer → short reply. Long answer → you can share more.
3. **One question at a time** - Never ask 2+ questions in one response
4. **Flow naturally** - Don't jump topics randomly, build on what they said
5. **Have a personality** - Have opinions, preferences, experiences (fictional is OK)
"""
    
    # ========== 5. 记忆使用 ==========
    memory_section = ""
    if memory_context:
        memory_section = f"""
## 🧠 CONVERSATION MEMORY
{memory_context}
→ Use this context naturally! Reference things they mentioned before.
"""
    
    # ========== 6. 特殊情况处理 ==========
    special_cases = """
## ⚠️ SPECIAL SITUATIONS

**If they give short answers (1-3 words):**
- Don't push! Give a short, warm response
- Maybe share something yourself to give them space
- Example: User: "yeah" → You: "😊" or "Cool!" (then wait)

**If they seem excited (long response):**
- Match their energy! Share your enthusiasm
- Can ask follow-up questions

**If they share something personal:**
- Show empathy first, don't immediately ask more
- "That sounds tough..." / "I can imagine..."

**If they ask YOU a question:**
- Answer it! Have an opinion/experience to share
- Then naturally turn it back to them
"""
    
    # ========== 7. 输出规则 ==========
    output_rules = """
## 📝 OUTPUT FORMAT
- Natural spoken English (no markdown, no bullet points)
- Include emotion where appropriate (😊 😅 etc. sparingly)
- This will be spoken aloud, so write how you'd actually TALK
"""
    
    # 日志
    logger.info(f"[PROMPT] get_pipeline_system_prompt_with_memory | version={PROMPT_VERSION} | level={level} | returning={is_returning_user} | interests={len(interests_list)}")
    
    return f"""You are chatting with someone who's practicing English. Be a genuine friend, not a language teacher.
{user_portrait}
{language_guide}
{chat_mode}
{memory_section}
{special_cases}
{output_rules}
"""


def get_pipeline_user_prompt_with_memory(
