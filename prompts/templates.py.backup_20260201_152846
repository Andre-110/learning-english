    else:
        user_context = f"""
## 🎯 THIS IS A NEW USER! First conversation - make them feel WELCOME!
{interests_prompt if interests_prompt else '(No interests known yet)'}
"""
    
    # 🆕 根据用户状态生成不同的开场白指令
    if is_returning and is_long_time:
        # 久违的老用户
        greeting_style = """
