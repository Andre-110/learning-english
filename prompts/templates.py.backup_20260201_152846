# 4. 初始问候语
# ==========================================

def get_initial_question_prompt(user_profile: Optional[Dict[str, Any]] = None) -> str:
    """
    生成初始问候语 - S2S 模式下作为开场语音
    
    设计原则（参考豆包、会议纪要）：
    - 普适性：话题要大众化，用户容易接话
    - 亲和力：像朋友聊天，不是面试官
    - 情境型开放问题：不问事实，问感受/故事
    - 安全性：不涉及偏门话题
    - 低压力：不要让用户感到被考试
    """
    level = "beginner"
    interests_str = ""
    encouragement = "You can answer in simple words or even mix some Chinese!"
    
    if user_profile:
        cefr = user_profile.get('cefr_level', 'A1')
        if cefr in ['A1', 'A2']:
            level = "beginner"
            encouragement = "You can answer in simple words or even mix some Chinese!"
        elif cefr in ['B1', 'B2']:
            level = "intermediate"
            encouragement = "Feel free to answer naturally!"
        else:
            level = "advanced"
            encouragement = "Just speak naturally!"
        
        # 提取用户兴趣
        interests = user_profile.get('interests', [])
        if isinstance(interests, list):
            valid_interests = [i for i in interests if isinstance(i, str)]
            if valid_interests:
                recent = valid_interests[::-1][:2]
                interests_str = f"\nUser interests: {', '.join(recent)}"
    
    # 随机选择问候风格
    styles = ["friendly", "curious", "warm"]
    style = random.choice(styles)
    
    return f"""Start a casual English conversation with a {level} learner.{interests_str}

Style: {style}
Under 25 words. English only.

## SCENARIO-BASED OPEN QUESTIONS (情境型开放问题)
Ask about FEELINGS or STORIES, not facts. Make them WANT to share.

✅ GOOD OPENERS (invite stories):
- "Hey! What's something that made you smile today?" 
- "Hi! If you had a free day tomorrow, what would you do?"
- "Hey there! What's been the highlight of your week so far?"
- (If interests: basketball) "Hey! What got you into basketball? What do you love about it?"

❌ BAD OPENERS (fact-based, get short answers):
- "How are you?" (too generic → "I'm fine")
- "What's your hobby?" (fact question → one word answer)
- "Do you like sports?" (Yes/No question)

## KEY RULE: Make them feel RELAXED, not tested!
- End with: "({encouragement})"
- Sound like a curious friend, NOT an interviewer

🚫 DO NOT mention: specific movies/shows, news, science topics, weather.

Output only your opening line (with the encouragement in parentheses)."""


