Reply naturally. Do not repeat what they said."""


def get_pipeline_initial_prompt(
    user_profile: Optional[Dict[str, Any]] = None,
    last_summary: Optional[Dict[str, Any]] = None
) -> str:
    """
    三段链路初始问候语 Prompt - 朋友式个性化开场
    
    🆕 2026-02 更新：区分新老用户，使用个人信息创造朋友式体验
    
    设计原则：
    - 新用户：温暖欢迎，轻松开场
    - 老用户：记得上次聊天，延续关系
    - 久违用户：表达想念，询问近况
    """
    import random
    from datetime import datetime, timedelta
    
    level = "beginner"
    interests_prompt = ""
    user_context = ""
    is_returning = False
    is_long_time = False
    display_name = ""
    last_topic = ""
    memorable_moments = []
    
    if user_profile:
        cefr = user_profile.get('cefr_level', 'A1')
        if cefr in ['A1', 'A2']:
            level = "beginner"
        elif cefr in ['B1', 'B2']:
            level = "intermediate"
        else:
            level = "advanced"
        
        # 🆕 检查是否是老用户
        conversation_count = user_profile.get('conversation_count', 0)
        is_returning = conversation_count > 0
        
        # 🆕 用户昵称
        display_name = user_profile.get('display_name', '')
        
        # 🆕 印象深刻的话题
        memorable_moments = user_profile.get('memorable_moments', [])
        
        # 🆕 上次对话主题
        last_topic = user_profile.get('last_conversation_topic', '')
        
        # 🆕 检查是否久违（超过7天）
        last_date_str = user_profile.get('last_conversation_date', '')
        if last_date_str:
            try:
                last_date = datetime.fromisoformat(last_date_str.replace('Z', '+00:00'))
                days_since = (datetime.now(last_date.tzinfo) - last_date).days
                is_long_time = days_since > 7
            except:
