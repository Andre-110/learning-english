        # 提取用户兴趣
        interests = user_profile.get('interests', [])
        if isinstance(interests, list):
            valid_interests = [i for i in interests if isinstance(i, str)]
            if valid_interests:
                recent_interests = valid_interests[::-1][:3]
                interests_str = ', '.join(recent_interests)
                interests_prompt = f"\nUser's interests: {interests_str}"
    
    # 🆕 使用上次对话摘要
    if last_summary:
