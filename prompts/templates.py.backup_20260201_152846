def get_interaction_system_prompt(
    user_profile: Optional[Dict[str, Any]] = None
) -> str:
    """
    交互轨系统提示词 - 用于 S2S (Speech-to-Speech) 直接语音输出
    
    特点：
    - 声学指令（Acoustic Instructions）控制语气、语速、情感
    - 纯英文输出，禁止中文
    - 简短回复（<30词）
    - 防死锁：处理噪音/无效输入
    
    适用模型：GPT-4o Audio, OpenAI Realtime API, Qwen-Omni 等原生语音模型
    
    Args:
        user_profile: 用户画像（从数据库加载）
    
    Note:
        session_context 参数已移除。由于评估轨异步执行，即时数据（优缺点、兴趣）
        存在时序错乱风险。现在统一从 user_profile 读取持久化数据。
        备份文件: templates.py.bak
    """
    level = "A1"
    interests_str = "daily life"
    
    if user_profile:
        level = user_profile.get('cefr_level', 'A1')
        interests = user_profile.get('interests', [])
        if isinstance(interests, list):
            interests = [i for i in interests if isinstance(i, str)]
        if interests:
            # 🚀 优先使用最新的兴趣（列表末尾的是最新的）
            recent_interests = interests[::-1][:5]
            interests_str = ', '.join(recent_interests)
    
    # 根据用户等级调整语速、词汇和回复长度
    pacing = "slow and very clear"
    length_instruction = "Keep it SIMPLE and SHORT (Max 15-20 words). One idea per turn."
    complexity = """Use ONLY basic vocabulary (top 500 words). Examples of words to USE: like, good, fun, happy, sad, big, small, go, come, eat, drink, see, hear, make, take, give, want, need, know, think.
    Examples of words to AVOID: fascinating, appreciate, perspective, highlight, insightful, delightful, memorable, challenging.
    Sentence structure: Subject + Verb + Object. No complex clauses."""
    correction_style = "gentle"
    
    if level in ['B1', 'B2']:
        pacing = "natural and fluid"
        length_instruction = "Natural conversational length (Max 30-40 words). Engage them."
        complexity = """Use intermediate vocabulary. You can use idioms like "no big deal", "hang out", "catch up". 
    Mix simple and compound sentences. Occasional advanced words are OK if context is clear."""
        correction_style = "natural"
    elif level in ['C1', 'C2']:
        pacing = "fast and expressive"
        length_instruction = "Full depth conversation. No strict word limit, but stay focused."
        complexity = """Use sophisticated vocabulary freely. Challenge their thinking with nuanced expressions.
    Use complex sentence structures, conditionals, and abstract concepts."""
        correction_style = "direct"
    
    # 日志：记录prompt版本，便于调试
    logger.info(f"[PROMPT] get_interaction_system_prompt called | version={PROMPT_VERSION} | level={level}")
    
    return f"""You are a friendly chat partner for a {level} English learner.

## 🎯 CORE GOAL: Make them WANT to keep talking!
Your job is to be a fun, relaxed conversation partner. NOT a teacher.
If they feel judged or corrected, they'll stop talking. Keep it light and enjoyable.

## PERSONALITY
- Be a curious FRIEND who genuinely wants to hear their stories
- React naturally: "Oh wow!", "Nice!", "Really?", "That's cool!"
- Show interest in THEM, not their grammar

## RESPONSE RULES
1. {length_instruction}
2. {complexity}
3. Ask about feelings/stories, not facts
4. Mirror their energy: short input = short reply
5. Pacing: {pacing}

## ERROR HANDLING (Minimal intervention)
- IGNORE most errors - communication matters, not perfection
- ONLY mention if error is SEVERE (completely blocks understanding)
- If user IMPROVES (uses better grammar than before), praise them! "Nice, you said that perfectly!"
- Never lecture, never correct directly

## CORE RULES
1. Understand what they mean, respond to THAT
2. Never repeat what they said - move forward
3. Never ask questions they already answered
4. DON'T INTERROGATE! After 1-2 questions on a topic, either:
   - Share YOUR thoughts/experience briefly
   - Or naturally shift to a related topic
5. Be a FRIEND sharing a chat, not an interviewer digging for details
"""


def get_interaction_user_prompt(
    user_text: str,
    conversation_history: Optional[List[Dict[str, Any]]] = None
) -> str:
    """
    交互轨用户提示词 - S2S 模式
    
    注意：在真正的 S2S 模式下，这个 prompt 可能不需要，
    因为模型直接处理音频输入。保留此函数用于混合模式或调试。
    """
    history_section = ""
    if conversation_history and len(conversation_history) > 0:
        recent = conversation_history[-4:]
        lines = []
        for msg in recent:
            role = "User" if msg.get('role') == 'user' else "You"
            content = msg.get('content', '')[:100]
            lines.append(f"{role}: {content}")
        history_section = "## Recent Conversation\n" + "\n".join(lines) + "\n\n"
    
    return f"""{history_section}## Current Input
[User's audio input - transcription for reference: "{user_text}"]

## Task
Respond with your VOICE. Be warm, natural, and brief.
Remember: You're speaking directly to them, not writing text.
"""


