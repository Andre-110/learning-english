    elif is_returning:
        # 老用户但没有特定话题
        greeting_style = """
## GREETING STYLE: FAMILIAR FRIEND! 😊
- Acknowledge the relationship: "Hey! Nice to chat again!"
- Ask what's new: "What's been going on?" or "What's new with you?"
- Keep it casual and warm
