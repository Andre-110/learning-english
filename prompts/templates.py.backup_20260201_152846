# 对话节奏引导（阶段 2 新增）
# ==========================================

def analyze_conversation_rhythm(
    conversation_history: Optional[List[Dict[str, Any]]] = None
) -> Dict[str, Any]:
    """
    分析对话历史，返回节奏建议
    
    用于在生成 AI 回复前，根据用户的回答模式调整策略。
    """
    SHORT_THRESHOLD = 5  # 短答词数阈值
    CONSECUTIVE_SHORT_TRIGGER = 2  # 连续短答触发换话题
    
    hints = {
        "consecutive_short_count": 0,
        "last_response_length": "normal",  # short / normal / long
        "suggested_strategy": "continue",  # continue / switch_topic / lighten / summarize
        "rhythm_instruction": ""  # 给 AI 的节奏引导
    }
    
    if not conversation_history:
        return hints
    
    # 统计最近用户消息的长度
    consecutive_short = 0
    last_user_msg = None
    
    for msg in reversed(conversation_history):
        if msg.get('role') == 'user':
            content = msg.get('content', '')
            word_count = len(content.split())
            
            if last_user_msg is None:
                last_user_msg = content
                hints["last_response_length"] = (
                    "short" if word_count <= SHORT_THRESHOLD else
                    "long" if word_count >= 20 else "normal"
                )
            
            if word_count <= SHORT_THRESHOLD:
                consecutive_short += 1
            else:
                break
    
    hints["consecutive_short_count"] = consecutive_short
    
    # 生成策略和引导语
    if consecutive_short >= CONSECUTIVE_SHORT_TRIGGER:
        hints["suggested_strategy"] = "switch_topic"
        hints["rhythm_instruction"] = """
⚠️ RHYTHM ALERT: User has given {count} short answers in a row.
ACTION REQUIRED: 
- Acknowledge briefly ("I see!", "Got it!")
- Switch to a LIGHTER, DIFFERENT topic
- Or offer 2 easy choices: "Would you rather talk about X or Y?"
- Do NOT keep probing the same topic!
""".format(count=consecutive_short)
    
    elif hints["last_response_length"] == "short":
        hints["suggested_strategy"] = "lighten"
        hints["rhythm_instruction"] = """
⚠️ RHYTHM NOTE: User gave a short answer.
ACTION: Ask ONE simple follow-up. If they stay brief, offer a choice or switch topic.
Do NOT ask multiple questions or probe deeply.
"""
    
    elif hints["last_response_length"] == "long":
        hints["suggested_strategy"] = "summarize"
        hints["rhythm_instruction"] = """
✨ RHYTHM NOTE: User shared a detailed response!
ACTION: 
- Acknowledge their sharing warmly
- Pick ONE interesting point to explore
- Or summarize briefly and extend to a related topic
"""
    
    return hints


def get_rhythm_instruction(
    conversation_history: Optional[List[Dict[str, Any]]] = None
) -> str:
    """
    获取节奏引导文本，直接嵌入到 Prompt 中
    """
    hints = analyze_conversation_rhythm(conversation_history)
    return hints.get("rhythm_instruction", "")


